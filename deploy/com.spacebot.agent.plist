<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.spacebot.agent</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/chandima/.local/bin/spacebot-wrapper.sh</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>
    
    <key>StandardOutPath</key>
    <string>/Users/chandima/.spacebot/launchd.out.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/chandima/.spacebot/launchd.err.log</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/chandima/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>GH_TOKEN</key>
        <string>${GH_TOKEN}</string>
    </dict>
    
    <key>WorkingDirectory</key>
    <string>/Users/chandima</string>
    
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
