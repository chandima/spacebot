# LiteLLM Custom Provider
[llm.provider.litellm]
api_type = "openai_completions"
base_url = "https://litellm.sandbox.iamzone.dev"
api_key = "${LITELLM_API_KEY}"
name = "LiteLLM Gateway"

# Model routing configuration
# Available models (NO Claude/Sonnet models available):
# - gpt-5.4 (premium, best quality)
# - gpt-5.3-codex (specialized for coding)
# - kimi-k2.5 (strong general purpose)
# - gpt-5-mini (fast, budget-friendly)
# - gpt-5-nano (ultra-fast, smallest)
# - glm-4.7-flash (fast Chinese model)
# - qwen3-coder-480b (massive coding model)
# - nova-premier, nova-pro, nova-lite (AWS Bedrock)

# Timezone for cron jobs (under defaults section is correct)

[defaults]
cron_timezone = "America/Phoenix"
worker_log_mode = "all_separate"

[defaults.routing]
channel = "github-copilot/claude-opus-4.6"    # Orchestrator: strongest reasoning
worker = "github-copilot/gpt-5-mini"          # Background tasks: fast/cheap via Codex
branch = "github-copilot/gpt-5-mini"          # Parallel tasks: fast/cheap via Codex
compactor = "openai-chatgpt/gpt-5.1-codex-mini"     # Context compression: ultra-fast 1M ctx
cortex = "openai-chatgpt/gpt-5.1-codex-mini"        # System observer: ultra-fast

# Task-specific overrides for optimal routing
[defaults.routing.task_overrides]
coding = "openai-chatgpt/gpt-5.3-codex"       # Use Codex for coding tasks

# Fallback chain across providers
[defaults.routing.fallbacks]
"github-copilot/claude-opus-4.6" = ["github-copilot/claude-sonnet-4.5", "openai-chatgpt/gpt-5.4"]
"openai-chatgpt/gpt-5.3-codex" = ["github-copilot/gpt-5.3-codex", "github-copilot/gpt-5-mini"]
"openai-chatgpt/gpt-5.1-codex-mini" = ["openai-chatgpt/gpt-5.1-codex-mini", "openai-chatgpt/gpt-5.4-mini"]

# OpenCode integration for code editing
[defaults.opencode]
enabled = true
path = "/opt/homebrew/bin/opencode"

# Sandbox environment passthrough
[defaults.sandbox]
mode = "disabled"
passthrough_env = ["GH_TOKEN", "GITHUB_TOKEN"]

# Slack Messaging Configuration
[messaging.slack]
enabled = true
bot_token = "${SLACK_BOT_TOKEN}"
app_token = "${SLACK_APP_TOKEN}"
dm_allowed_users = ["U0AP6GNB91V"]

# MCP Servers
[[defaults.mcp]]
name = "searxng"
transport = "stdio"
enabled = true
command = "/Users/chandima/.volta/bin/mcp-searxng"
args = []

[defaults.mcp.env]
SEARXNG_URL = "https://searxng.sandbox.iamzone.dev"

[[defaults.mcp]]
name = "microsoft"
transport = "stdio"
enabled = true
command = "/opt/homebrew/bin/npx"
args = ["-y", "@softeria/ms-365-mcp-server", "--preset", "calendar,mail,contacts,files"]

[defaults.mcp.env]
MS365_MCP_CLIENT_ID = "4b3175cd-bab2-48fa-9b1d-51724e3732e5"
MS365_MCP_TOKEN_CACHE_PATH = "/Users/chandima/.spacebot/ms365/token-cache.json"
MS365_MCP_SELECTED_ACCOUNT_PATH = "/Users/chandima/.spacebot/ms365/selected-account.json"
PATH = "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# Browser configuration
[defaults.browser]
persist_session = true

# Default agent configuration
[[agents]]
id = "default-agent"
name = "Spacebot"
[[agents.mcp]]
name = "enterprise-slack"
transport = "stdio"
enabled = false
command = "/bin/true"

# Slack Integration Agent — Enterprise Slack read-only access
[[agents]]
id = "slack-agent"
display_name = "Slack"
role = "Enterprise Slack search, conversation history, user lookup, and channel monitoring"
max_concurrent_workers = 2
max_turns = 10

[agents.routing]
channel = "github-copilot/gpt-5-mini"
worker = "github-copilot/gpt-5-mini"
branch = "github-copilot/gpt-5-mini"
compactor = "openai-chatgpt/gpt-5.1-codex-mini"
cortex = "openai-chatgpt/gpt-5.1-codex-mini"

# Architect agent — problem framing, scope review, architecture lock
[[agents]]
id = "architect-agent"
display_name = "Architect"
role = "Problem framing, scope review, architecture lock, and design document production"
max_concurrent_workers = 3
max_turns = 15
[[agents.mcp]]
